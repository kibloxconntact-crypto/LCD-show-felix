#!/bin/bash
# -------------------------------
# HDMI + 3.5" SPI Display Setup
# Pi läuft immer, Mini-Display optional
# -------------------------------

# --- Backup und Ordner ---
sudo ./system_backup.sh

if [ -f /etc/X11/xorg.conf.d/40-libinput.conf ]; then
    sudo rm -rf /etc/X11/xorg.conf.d/40-libinput.conf
fi

if [ ! -d /etc/X11/xorg.conf.d ]; then
    sudo mkdir -p /etc/X11/xorg.conf.d
fi

# --- Backup config.txt ---
sudo cp -rf ./boot/config.txt ./boot/config.txt.bak

# --- HDMI Fixes ---
sudo bash -c 'cat <<EOF >> ./boot/config.txt.bak
hdmi_force_hotplug=1
hdmi_group=2
hdmi_mode=82
hdmi_drive=2
EOF'

# --- I2C, SPI, UART ---
sudo bash -c 'cat <<EOF >> ./boot/config.txt.bak
dtparam=i2c_arm=on
dtparam=spi=on
enable_uart=1
EOF'

# --- TFT Overlay aktivieren ---
sudo bash -c 'cat <<EOF >> ./boot/config.txt.bak
dtoverlay=tft35a:rotate=90
EOF'

# --- Config zurück nach /boot ---
sudo cp -rf ./boot/config.txt.bak /boot/config.txt

# --- Kalibrierung nur, wenn Display aktiv ---
sudo cp -rf ./usr/99-calibration.conf-35-90 /etc/X11/xorg.conf.d/99-calibration.conf

# --- Optional: Display Toggle Script ---
TOGGLE_SCRIPT=~/tft_sleep_toggle.sh
cat <<'EOL' > $TOGGLE_SCRIPT
#!/bin/bash
BL_PIN=18
# GPIO exportieren
if [ ! -d /sys/class/gpio/gpio$BL_PIN ]; then
    echo $BL_PIN > /sys/class/gpio/export
    echo out > /sys/class/gpio/gpio$BL_PIN/direction
fi
# Status prüfen
BL_STATUS=$(cat /sys/class/gpio/gpio$BL_PIN/value)
if [ "$BL_STATUS" -eq 1 ]; then
    # Display ausschalten
    echo 0 > /sys/class/gpio/gpio$BL_PIN/value
    sudo sh -c 'cat /dev/zero > /dev/fb1'
    echo "Mini-Display in Sleep"
else
    # Display einschalten
    echo 1 > /sys/class/gpio/gpio$BL_PIN/value
    echo "Mini-Display aktiv"
fi
EOL

chmod +x $TOGGLE_SCRIPT

# --- FBCP überspringen ---
echo "Framebuffer Copy übersprungen (optional, falls Mini-Display Spiegelung benötigt)"

# --- sync & reboot ---
sudo sync
sleep 1
echo "HDMI + Mini-Display Setup abgeschlossen."
echo "Pi wird neu gestartet..."
sudo reboot
